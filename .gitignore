# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# macOS Finder duplicates — when Finder copies a file into a directory
# that already has one with the same name it appends ` 2`, ` 3`, etc.
# before the extension (e.g. `parse-receipt 4.ts`). They show up in
# this repo most often when grabbing a file out of an iCloud-synced
# directory. They're never intentional; ignoring the pattern keeps
# them out of `git status` and prevents accidental commits.
* [0-9].ts
* [0-9].tsx
* [0-9].mjs
* [0-9].cjs
* [0-9].js
* [0-9].jsx
* [0-9].json
* [0-9].sql
* [0-9].md

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# local attachment storage (files table bytes when running without R2)
/.uploads/

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code
.claude/
