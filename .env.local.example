# Copy to .env.local and fill in values (see README).

DATABASE_URL=

# Optional: Neon direct / unpooled URL for migrations and db:import-customers.
# DATABASE_URL_UNPOOLED=

# Domain only — no protocol, no trailing slash. e.g. "app.example.com" or "localhost"
ROOT_DOMAIN=localhost

BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

ERP_API_ORIGIN=http://127.0.0.1:8000

# Stripe (subscription Checkout + webhooks; optional until you enable billing)
# STRIPE_SECRET_KEY=
# Signing secret — must match HOW events reach this app:
# - Stripe CLI forwards: paste the `whsec_...` from `stripe listen` (changes when CLI restarts) and restart `npm run dev`.
# - Production URL in Dashboard: paste that endpoint's "Reveal signing secret" (`whsec_...`). Never mix CLI vs Dashboard secrets.
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_STARTER=
# STRIPE_PRICE_GROWTH=
# STRIPE_PRICE_ENTERPRISE=
# ^ Fallback when no DB row in stripe_prices for that plan; configure Stripe Price/Product metadata `plan=starter|growth|enterprise` then sync (see docs/stripe-subscriptions.md).
# Public site URL for Checkout redirects (optional; falls back to BETTER_AUTH_URL / Vercel)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: support / admin contact email (shown in forgot-password success toast; NEXT_PUBLIC_* is required for client components).
# NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com
