# Copy to .env.local and fill in values (see README).

# Neon URLs should use `sslmode=verify-full&channel_binding=require`.
DATABASE_URL=

# Optional: Neon direct / unpooled URL for migrations (`npm run db:migrate`) and db:import-customers.
# If set alongside DATABASE_URL, use the same Neon **database/branch** for both (pooled vs direct differ by host only).
# If you only set one, `DATABASE_URL_UNPOOLED` alone is enough for migrate; the app also accepts it when DATABASE_URL is unset.
# DATABASE_URL_UNPOOLED=

# Dev warning: pointing DATABASE_URL at localhost and UNPOOLED at Neon means migrations update Neon while the app reads local — missing tables such as stripe_prices.

# Domain only — no protocol, no trailing slash. e.g. "app.example.com" or "localhost"
ROOT_DOMAIN=localhost

BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

ERP_API_ORIGIN=http://127.0.0.1:8000

# Stripe (subscription Checkout + webhooks; optional until you enable billing)
# STRIPE_SECRET_KEY=
# Signing secret — must match HOW events reach this app:
# - Stripe CLI forwards: paste the `whsec_...` from `stripe listen` (changes when CLI restarts) and restart `npm run dev`.
# - Production URL in Dashboard: paste that endpoint's "Reveal signing secret" (`whsec_...`). Never mix CLI vs Dashboard secrets.
# STRIPE_WEBHOOK_SECRET=
# Prices come exclusively from the synced catalog (stripe_prices). Seed with
# `pnpm stripe:seed`, set Stripe Price/Product metadata `plan=starter|growth|enterprise`,
# then run "Sync Stripe catalog" in Admin → Subscriptions (see docs/stripe-subscriptions.md).
# Public site URL for Checkout redirects (optional; falls back to BETTER_AUTH_URL / Vercel)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: support / admin contact email (shown in forgot-password success toast; NEXT_PUBLIC_* is required for client components).
# NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com

# Sentry error tracking (optional in dev — leave blank to no-op).
# Server-side DSN is read by sentry.{server,edge}.config.ts.
# SENTRY_DSN=
# Same DSN, exposed to the client bundle (public by design — DSNs are not secrets).
# NEXT_PUBLIC_SENTRY_DSN=
# Used by withSentryConfig at build time only to upload source maps + tag releases.
# Never reference these at runtime.
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# Vercel Cron secret. Vercel sets this automatically on cron invocations as
# `Authorization: Bearer ${CRON_SECRET}`. Generate a random value and set it
# in Vercel project env so /api/cron/* endpoints can authenticate the caller.
# CRON_SECRET=

# Upstash Redis for app-layer rate limiting. Leave blank in dev — every
# limiter no-ops when these are unset so the app continues to work.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Better Stack uptime heartbeats. Generated when each heartbeat is created
# in the Better Stack dashboard. When unset, `pingHeartbeat()` is a no-op
# so the cron jobs continue to run without Better Stack provisioned.
# See GitHub issue for the dashboard setup checklist (monitors, status page,
# Slack routing). Only WEBHOOK_DEDUPE_CLEANUP has a wired call site today;
# the other three crons need to be built before their heartbeat will fire.
# BETTER_STACK_HEARTBEAT_URL_PLAID_SYNC=
# BETTER_STACK_HEARTBEAT_URL_BALANCE_SNAPSHOT=
# BETTER_STACK_HEARTBEAT_URL_AUDIT_CLEANUP=
# BETTER_STACK_HEARTBEAT_URL_WEBHOOK_DEDUPE_CLEANUP=

# Resend transactional email (required — lib/email.ts throws at boot when unset).
# EMAIL_FROM is the shared sender for non-tenant-aware emails (password reset,
# tenant-join invites, etc.). For local dev set it to a Resend-verified address
# you own (free tier only lets you send to that same address). In production
# the bill-forward path swaps to tenant-aware From by default; set
# EMAIL_FROM_OVERRIDE there if you want to force the single-sender shape.
# RESEND_API_KEY=
# EMAIL_FROM="Local Dev <you@your-verified-domain.com>"
# EMAIL_FROM_OVERRIDE=
# Local-only safety net for the bill-forward path: when set, every
# forwardBillAction sends to this address instead of the recipients the
# user typed. The DB row + audit log still record the original intended
# recipients (so the prod-shape data isn't disturbed). Leave unset in
# staging/prod.
# EMAIL_FORWARD_OVERRIDE_TO=you@your-verified-domain.com

# PostHog activation analytics. When the NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN is unset,
# the client SDK never initializes and every captureClientEvent is a no-op.
# Same for the server: captureServerEvent short-circuits when
# POSTHOG_PROJECT_API_KEY is unset. The host defaults to US Cloud.
# NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# POSTHOG_PROJECT_API_KEY=
